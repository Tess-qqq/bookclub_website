# Your deployed Vercel URL (no trailing slash). Used by the API route for CORS.
APP_URL="https://your-app.vercel.app"

# ── Client-side (Vite exposes these to the browser) ─────────────────────────
# Admin PIN — shown in the browser UI for gating admin actions.
# The real auth check is in /api/admin/events (server-side).
VITE_ADMIN_PIN="serin2024"

# Optionally override the API base URL in dev
# VITE_APP_URL="http://localhost:3000"

# ── Server-side (Vercel Serverless Functions only) ───────────────────────────
# The SAME admin PIN — verified server-side so the route is truly protected.
ADMIN_PIN="serin2024"

# Firebase Admin SDK credentials (from your Firebase project → Service Accounts)
FIREBASE_PROJECT_ID="your-project-id"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com"
# Paste the private key value; Vercel stores it safely.
# In the Vercel dashboard, paste the raw key including -----BEGIN/END----- lines.
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
