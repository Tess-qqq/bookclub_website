rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function isValidBook(data) {
      return data.keys().hasAll(['title', 'author', 'uniId', 'createdAt'])
        && data.keys().size() == 4
        && data.title is string && data.title.size() > 0 && data.title.size() <= 200
        && data.author is string && data.author.size() > 0 && data.author.size() <= 200
        && data.uniId in ['AMU', 'AITU', 'NU']
        && data.createdAt == request.time;
    }

    match /books/{bookId} {
      allow list: if true;
      allow get: if isValidId(bookId);
      allow create: if isValidId(bookId) && isValidBook(incoming());
      allow update, delete: if false;
    }
  }
}
